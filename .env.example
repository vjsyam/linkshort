# =============================================================================
# LinkShort — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- REQUIRED ---

# JWT signing secret (min 32 characters, use a random string)
# Generate one: openssl rand -base64 48
JWT_SECRET=

# --- DATABASE (Production) ---
DATABASE_URL=jdbc:postgresql://localhost:5432/linkshort
DATABASE_USER=linkshort
DATABASE_PASSWORD=

# --- OPTIONAL ---

# Public-facing base URL for short links (e.g., https://lnk.sh)
# Set to "auto" for local dev (auto-detects LAN IP)
APP_BASE_URL=auto

# Comma-separated list of allowed CORS origins
# e.g., https://your-frontend.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Redis host/port (only needed if running with Redis cache)
REDIS_HOST=localhost
REDIS_PORT=6379
